{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/agent4math/paper-parser/schema/index.schema.json",
  "title": "PaperParser index.json schema",
  "description": "Schema for the index (enrichment) file of a PaperParser bundle. Provides narrative summaries, proof strategies, clusters, unknowns, and statistics layered on top of the graph.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "problem_statement",
    "innovation_assessment",
    "clusters",
    "main_results",
    "proof_strategies",
    "summaries",
    "attention",
    "unknowns",
    "notation_index",
    "stats"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Semver version of the PaperParser schema specification. Must match manifest.json schema_version."
    },
    "problem_statement": {
      "$ref": "#/$defs/problem_statement"
    },
    "innovation_assessment": {
      "$ref": "#/$defs/innovation_assessment"
    },
    "clusters": {
      "type": "array",
      "description": "Groupings of related nodes by section, topic, or technique.",
      "items": { "$ref": "#/$defs/cluster" }
    },
    "main_results": {
      "type": "array",
      "description": "The headline theorems/results of the paper. At least one entry is expected for a valid analysis.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/main_result" }
    },
    "proof_strategies": {
      "type": "array",
      "description": "Proof outlines for main results and other important proved statements.",
      "items": { "$ref": "#/$defs/proof_strategy" }
    },
    "summaries": {
      "type": "array",
      "description": "Per-section narrative summaries.",
      "items": { "$ref": "#/$defs/section_summary" }
    },
    "attention": {
      "$ref": "#/$defs/attention"
    },
    "unknowns": {
      "type": "array",
      "description": "Gaps, unclear points, or unverified claims identified during analysis. May be empty.",
      "items": { "$ref": "#/$defs/unknown" }
    },
    "notation_index": {
      "type": "array",
      "description": "Symbol-to-meaning mapping for mathematical notation used in the paper.",
      "items": { "$ref": "#/$defs/notation_entry" }
    },
    "stats": {
      "$ref": "#/$defs/stats"
    }
  },
  "$defs": {
    "node_id_ref": {
      "type": "string",
      "pattern": "^sec[0-9A-Za-z]+(\\.[0-9A-Za-z]+)*::(def|thm|lem|prop|cor|asm|rem|ex|conj|not|ext):[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "description": "Reference to a node ID defined in graph.json."
    },
    "problem_statement": {
      "type": "object",
      "description": "The paper's central question and context.",
      "additionalProperties": false,
      "required": ["question", "motivation", "context"],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1,
          "description": "The central mathematical question the paper addresses, in a single sentence or short paragraph."
        },
        "motivation": {
          "type": "string",
          "minLength": 1,
          "description": "Why this question matters: applications, open-problem status, or theoretical importance."
        },
        "context": {
          "type": "string",
          "minLength": 1,
          "description": "How this paper relates to prior work. Mention key predecessors."
        }
      }
    },
    "innovation_assessment": {
      "type": "object",
      "description": "Assessment of the paper's novelty and contributions.",
      "additionalProperties": false,
      "required": ["summary", "main_innovations", "prior_work_comparison"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "One-paragraph summary of what is new in this paper."
        },
        "main_innovations": {
          "type": "array",
          "description": "List of distinct innovations introduced by the paper.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["description", "calibration", "related_nodes"],
            "properties": {
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "What the innovation is."
              },
              "calibration": {
                "type": "string",
                "enum": ["significant", "incremental", "straightforward_extension"],
                "description": "Innovation significance: 'significant' (major new idea), 'incremental' (meaningful but builds on existing work), 'straightforward_extension' (routine generalization)."
              },
              "related_nodes": {
                "type": "array",
                "items": { "$ref": "#/$defs/node_id_ref" },
                "uniqueItems": true,
                "description": "Node IDs of graph nodes most closely tied to this innovation."
              }
            }
          }
        },
        "prior_work_comparison": {
          "type": "string",
          "minLength": 1,
          "description": "Explicit comparison with the most relevant prior results, noting what is improved and by how much."
        }
      }
    },
    "cluster": {
      "type": "object",
      "description": "A grouping of related nodes.",
      "additionalProperties": false,
      "required": ["id", "label", "members", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^cluster:[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
          "description": "Cluster ID in the format cluster:{label}."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable cluster name."
        },
        "section": {
          "type": "string",
          "description": "Section number, if the cluster corresponds to a single section."
        },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/node_id_ref" },
          "uniqueItems": true,
          "description": "Node IDs belonging to this cluster."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Short description of the cluster's role in the paper."
        }
      }
    },
    "main_result": {
      "type": "object",
      "description": "A headline result of the paper.",
      "additionalProperties": false,
      "required": ["node_id", "headline", "significance"],
      "properties": {
        "node_id": {
          "$ref": "#/$defs/node_id_ref",
          "description": "Node ID of the main result. Must reference a node with is_main_result: true."
        },
        "headline": {
          "type": "string",
          "minLength": 1,
          "description": "One-sentence summary of what the result says, suitable for a talk abstract."
        },
        "significance": {
          "type": "string",
          "minLength": 1,
          "description": "Why this result matters, in one to two sentences."
        }
      }
    },
    "proof_strategy": {
      "type": "object",
      "description": "Proof outline for a significant result.",
      "additionalProperties": false,
      "required": ["target_node", "strategy_summary", "key_steps"],
      "properties": {
        "target_node": {
          "$ref": "#/$defs/node_id_ref",
          "description": "Node ID of the result whose proof is being described."
        },
        "strategy_summary": {
          "type": "string",
          "minLength": 1,
          "description": "Paragraph-length overview of the proof strategy, describing the overall approach and key ideas."
        },
        "key_steps": {
          "type": "array",
          "description": "Ordered list of proof steps.",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["step", "description", "uses"],
            "properties": {
              "step": {
                "type": "integer",
                "minimum": 1,
                "description": "Step number (1-indexed)."
              },
              "description": {
                "type": "string",
                "minLength": 1,
                "description": "What happens in this step."
              },
              "uses": {
                "type": "array",
                "items": { "$ref": "#/$defs/node_id_ref" },
                "uniqueItems": true,
                "description": "Node IDs of definitions/lemmas/external results used in this step."
              }
            }
          }
        },
        "noise_removed": {
          "type": "string",
          "description": "Description of proof sections that are routine or can be skipped on first reading. Helps a reader triage their attention."
        }
      }
    },
    "section_summary": {
      "type": "object",
      "description": "Narrative summary of a single section.",
      "additionalProperties": false,
      "required": ["section", "section_title", "summary"],
      "properties": {
        "section": {
          "type": "string",
          "minLength": 1,
          "description": "Section number."
        },
        "section_title": {
          "type": "string",
          "description": "Section title."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "Narrative summary of the section (2-5 sentences). Should capture the section's role in the paper, not just list its contents."
        }
      }
    },
    "attention": {
      "type": "object",
      "description": "Highlights of structurally important or difficult parts of the paper.",
      "additionalProperties": false,
      "required": ["high_dependency_nodes", "demanding_proofs"],
      "properties": {
        "high_dependency_nodes": {
          "type": "array",
          "description": "Nodes with unusually high in-degree or out-degree in the graph.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["node_id", "in_degree", "out_degree", "note"],
            "properties": {
              "node_id": {
                "$ref": "#/$defs/node_id_ref",
                "description": "Node ID."
              },
              "in_degree": {
                "type": "integer",
                "minimum": 0,
                "description": "Number of edges pointing TO this node."
              },
              "out_degree": {
                "type": "integer",
                "minimum": 0,
                "description": "Number of edges pointing FROM this node."
              },
              "note": {
                "type": "string",
                "minLength": 1,
                "description": "Why this node deserves attention."
              }
            }
          }
        },
        "demanding_proofs": {
          "type": "array",
          "description": "Proofs that are especially long, complex, or subtle.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["node_id", "reason", "estimated_difficulty"],
            "properties": {
              "node_id": {
                "$ref": "#/$defs/node_id_ref",
                "description": "Node ID of the proved statement."
              },
              "reason": {
                "type": "string",
                "minLength": 1,
                "description": "Why the proof is demanding."
              },
              "estimated_difficulty": {
                "type": "string",
                "enum": ["low", "medium", "high"],
                "description": "Estimated difficulty level of the proof."
              }
            }
          }
        }
      }
    },
    "unknown": {
      "type": "object",
      "description": "A gap, unclear point, or unverified claim identified during analysis.",
      "additionalProperties": false,
      "required": ["id", "description", "search_hint", "scope", "related_nodes"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^unknown:[0-9]+$",
          "description": "Unique ID in the format unknown:{N}."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "What is unknown or unclear."
        },
        "search_hint": {
          "type": "string",
          "minLength": 1,
          "description": "Suggestion for where to look or what to check to resolve this unknown."
        },
        "scope": {
          "type": "string",
          "enum": ["proof_step", "section", "paper"],
          "description": "Scope of the unknown: 'proof_step' (localized), 'section' (section-level), 'paper' (paper-level conclusion)."
        },
        "related_nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/node_id_ref" },
          "uniqueItems": true,
          "description": "Node IDs relevant to this unknown."
        }
      }
    },
    "notation_entry": {
      "type": "object",
      "description": "A symbol-to-meaning mapping entry.",
      "additionalProperties": false,
      "required": ["symbol", "meaning", "introduced_in"],
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1,
          "description": "The mathematical symbol in LaTeX (e.g., '$\\\\|\\\\cdot\\\\|$')."
        },
        "meaning": {
          "type": "string",
          "minLength": 1,
          "description": "Plain-text explanation of what the symbol denotes."
        },
        "introduced_in": {
          "$ref": "#/$defs/node_id_ref",
          "description": "Node ID where this notation is first introduced."
        }
      }
    },
    "stats": {
      "type": "object",
      "description": "Aggregate counts for the bundle. Counts must be consistent with graph.json.",
      "additionalProperties": false,
      "required": ["node_counts", "edge_counts", "evidence_breakdown"],
      "properties": {
        "node_counts": {
          "type": "object",
          "description": "Object mapping each node kind to its count, plus a 'total' key. All eleven kinds must be present, even if the count is 0.",
          "additionalProperties": false,
          "required": [
            "definition",
            "theorem",
            "lemma",
            "proposition",
            "corollary",
            "assumption",
            "remark",
            "example",
            "conjecture",
            "notation",
            "external_dependency",
            "total"
          ],
          "properties": {
            "definition": { "type": "integer", "minimum": 0 },
            "theorem": { "type": "integer", "minimum": 0 },
            "lemma": { "type": "integer", "minimum": 0 },
            "proposition": { "type": "integer", "minimum": 0 },
            "corollary": { "type": "integer", "minimum": 0 },
            "assumption": { "type": "integer", "minimum": 0 },
            "remark": { "type": "integer", "minimum": 0 },
            "example": { "type": "integer", "minimum": 0 },
            "conjecture": { "type": "integer", "minimum": 0 },
            "notation": { "type": "integer", "minimum": 0 },
            "external_dependency": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          }
        },
        "edge_counts": {
          "type": "object",
          "description": "Object mapping each edge kind to its count, plus a 'total' key. All six kinds must be present, even if the count is 0.",
          "additionalProperties": false,
          "required": [
            "uses_in_proof",
            "extends",
            "generalizes",
            "specializes",
            "equivalent_to",
            "cites_external",
            "total"
          ],
          "properties": {
            "uses_in_proof": { "type": "integer", "minimum": 0 },
            "extends": { "type": "integer", "minimum": 0 },
            "generalizes": { "type": "integer", "minimum": 0 },
            "specializes": { "type": "integer", "minimum": 0 },
            "equivalent_to": { "type": "integer", "minimum": 0 },
            "cites_external": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          }
        },
        "evidence_breakdown": {
          "type": "object",
          "description": "Object mapping each evidence level to the number of edges with that level. All three levels must be present. Values must sum to edge_counts.total.",
          "additionalProperties": false,
          "required": ["explicit_ref", "inferred", "external"],
          "properties": {
            "explicit_ref": { "type": "integer", "minimum": 0 },
            "inferred": { "type": "integer", "minimum": 0 },
            "external": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
